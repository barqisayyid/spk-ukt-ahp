{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0"
        }
    },
    "rewrites": [
        {
            "source": "/build/assets/(.*)",
            "destination": "/public/build/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ],
    "outputDirectory": "."
}
